---
// 1. CONFIGURACIÓN SSR
export const prerender = false;

import "../../styles/global.css";
import Navbar from "../../components/Navbar.astro";
import Quiz from "../../components/Quiz.astro";
import Footer from "../../components/Footer.astro";
import StyleSafelist from "../../components/StyleSafelist.astro";
import { db } from "../../lib/firebase";
import { collection, query, where, getDocs, limit } from "firebase/firestore";
import { marked } from "marked";
import { BookOpen, Clock, Calendar, Link } from "lucide-astro";
import type { PostData } from "../../lib/types/post";

const { slug } = Astro.params;
let post: PostData | null = null;

try {
    const postsRef = collection(db, "metamorfosis_posts");
    const q = query(postsRef, where("metadata.slug", "==", slug), limit(1));
    const querySnapshot = await getDocs(q);

    if (!querySnapshot.empty) {
        const doc = querySnapshot.docs[0];
        // Asignamos el ID y los datos con el tipo correcto
        post = { id: doc.id, ...doc.data() } as PostData;
    }
} catch (error) {
    console.error("Error en SSR Firestore:", error);
}

// Validación de existencia
if (!post) {
    return Astro.redirect("/404");
}

// Procesamiento de contenido (Marked puede devolver Promise o string, forzamos string)
const rawBody = post.content?.body || "<p>No content available</p>";
const content = typeof marked.parse(rawBody) === 'string' 
    ? marked.parse(rawBody) 
    : await marked.parse(rawBody);

const formatDate = (dateString?: string) => {
    if (!dateString) return "Fecha no disponible";
    return new Date(dateString).toLocaleDateString("es-ES", {
        year: "numeric",
        month: "long",
        day: "numeric",
    });
};
---

<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta
            name="description"
            content={post.metadata?.seoDescription || "Artículo sobre salud metabólica"}
        />
        <title>{post.metadata?.seoTitle || "Post"} - Metamorfosis Real</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    </head>
    <body class="bg-gradient-to-br from-gray-50 via-white to-gray-50 font-sans text-gray-900 antialiased">
        <Navbar />

        <div class="min-h-screen">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
                <a href="/" class="inline-flex items-center gap-2 text-gray-600 hover:text-emerald-600 font-medium transition-colors duration-200 group">
                    <svg class="w-5 h-5 flex-shrink-0 transition-transform group-hover:-translate-x-1" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                    </svg>
                    Volver al inicio
                </a>
            </div>

            <div class="bg-gradient-to-r from-emerald-500 to-blue-600 text-white py-16 md:py-24 mt-8">
                <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                    {post.metadata?.category && (
                        <div class="mb-6">
                            <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/20 backdrop-blur-sm rounded-full text-sm font-semibold border border-white/30">
                                <BookOpen className="w-4 h-4" />
                                {post.metadata.category}
                            </span>
                        </div>
                    )}
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
                        {post.metadata?.seoTitle || "Título del Post"}
                    </h1>
                    <div class="flex flex-wrap items-center gap-4 text-white/90">
                        {post.metadata?.readingTime && (
                            <div class="flex items-center gap-2">
                                <Clock className="w-5 h-5" />
                                <span class="font-medium">{post.metadata.readingTime} min de lectura</span>
                            </div>
                        )}
                        {post.metadata?.publishedAt && (
                            <div class="flex items-center gap-2">
                                <Calendar className="w-5 h-5" />
                                <span class="font-medium">{formatDate(post.metadata.publishedAt)}</span>
                            </div>
                        )}
                    </div>
                </div>
            </div>

            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
                <article
                    class="prose prose-lg max-w-none prose-headings:font-bold prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-4 prose-p:text-gray-700 prose-p:leading-relaxed prose-a:text-emerald-600 prose-a:no-underline hover:prose-a:underline prose-strong:text-gray-900 prose-ul:my-6 prose-li:my-2 prose-blockquote:border-l-4 prose-blockquote:border-emerald-500 prose-blockquote:bg-emerald-50 prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:rounded-r-lg prose-img:rounded-xl prose-img:shadow-xl prose-img:object-cover prose-img:mx-auto prose-figure:my-10 prose-figcaption:text-center prose-figcaption:text-sm prose-figcaption:italic prose-figcaption:text-gray-500"
                    set:html={content}
                />

                {post.quiz && post.quiz.length > 0 && (
                    <div class="mt-16">
                        <Quiz questions={post.quiz} />
                    </div>
                )}

                {Array.isArray(post.references) && post.references.length > 0 && (
                    <div class="mt-16 bg-gray-50 border-t border-gray-200 pt-10 pb-12 px-8 rounded-2xl shadow-sm">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="p-2 bg-emerald-100 text-emerald-600 rounded-lg shadow-sm">
                                <Link className="w-5 h-5" />
                            </div>
                            <h3 class="text-2xl font-bold text-gray-900">Fuentes y Referencias Científicas</h3>
                        </div>
                        <ul class="space-y-4">
                            {post.references.map((ref, index) => (
                                <li class="flex items-start gap-4 p-5 bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md hover:border-emerald-100 transition-all">
                                    <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-gray-50 text-gray-500 font-bold text-sm border border-gray-100">
                                        {index + 1}
                                    </span>
                                    <div class="flex-1 min-w-0 pt-0.5">
                                        <p class="text-gray-900 font-semibold leading-snug mb-1.5 line-clamp-2">
                                            {ref.title}
                                        </p>
                                        <a 
                                            href={ref.url} 
                                            target="_blank" 
                                            rel="noopener noreferrer"
                                            class="inline-flex items-center gap-1.5 text-sm text-emerald-600 hover:text-emerald-700 font-medium truncate max-w-full transition-colors"
                                        >
                                            Ver documento original
                                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                            </svg>
                                        </a>
                                    </div>
                                </li>
                            ))}
                        </ul>
                    </div>
                )}

                {post.app_integration?.callToAction && (
                    <div class="mt-12 bg-gradient-to-r from-emerald-500 to-blue-600 rounded-2xl p-8 md:p-12 text-center shadow-xl">
                        <h3 class="text-2xl md:text-3xl font-bold text-white mb-4">🦋 Pasa a la acción</h3>
                        <p class="text-white/90 text-lg mb-6 max-w-2xl mx-auto">{post.app_integration.callToAction}</p>
                        <a href={post.app_integration.deepLink || "#"} class="inline-flex items-center gap-2 bg-white text-emerald-600 px-8 py-4 rounded-full font-bold text-lg hover:bg-gray-50 transition-all duration-200 shadow-lg hover:shadow-xl hover:scale-105">
                            Regístrate en ElenaApp para llevar tu registro →
                        </a>
                    </div>
                )}
            </div>
        </div>

        <Footer />
        <div style="display: none;"><StyleSafelist /></div>
        
        <style is:global>
            article.prose ol { counter-reset: my-counter; list-style: none; padding-left: 0; }
            article.prose ol > li { position: relative; counter-increment: my-counter; padding-left: 4rem; margin-bottom: 2rem; }
            article.prose ol > li::before { content: counter(my-counter); position: absolute; left: 0; top: 0; width: 2.5rem; height: 2.5rem; background-color: #007bff; color: white; font-weight: 700; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
            article.prose h2, article.prose h3 { position: relative; padding: 1rem 0 1rem 1.5rem; margin-top: 3.5rem; background: linear-gradient(to right, rgba(0, 196, 154, 0.1), transparent); border-left: 4px solid #00c49a; border-radius: 0 8px 8px 0; }
            
            /* Enhanced Article Visuals for AI generated imagery */
            article.prose img { 
                border-radius: 1rem; 
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1); 
                transition: transform 0.3s ease;
                border: 1px solid rgba(0,0,0,0.05);
            }
            article.prose img:hover {
                transform: scale(1.02);
            }
        </style>
    </body>
</html>