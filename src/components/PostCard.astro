---
import { Activity, Zap, Timer, TrendingDown, Wallet, BookOpen, Flame, Dumbbell } from "lucide-astro";

export interface Props {
    post: {
        id: string;
        title?: string;
        metadata?: {
            seoTitle?: string;
            seoDescription?: string;
            publishedAt?: string;
            slug?: string;
            category?: string;
            readingTime?: number;
            impact?: string;
            effort?: number | string;
            biomarker?: string;
        };
    };
}

const { post } = Astro.props;

// Category mapping helper
const getCategoryIcon = (category?: string) => {
    const cat = category?.toLowerCase() || '';
    if (cat.includes('salud') || cat.includes('metabolismo')) return Activity;
    if (cat.includes('ayuno')) return Timer;
    if (cat.includes('finanzas') || cat.includes('deuda')) return Wallet;
    return BookOpen;
};

const IconComponent = getCategoryIcon(post.metadata?.category);
const postTitle = post.metadata?.seoTitle || post.title || "Sin Título";
const postUrl = `/posts/${post.metadata?.slug || post.id}`;
const postCategory = post.metadata?.category || "Guía";
const publishedDate = post.metadata?.publishedAt 
    ? new Date(post.metadata.publishedAt).toLocaleDateString("es-ES", { month: "short", day: "numeric", year: "numeric" })
    : "N/A";
const readingTime = post.metadata?.readingTime || 5;
const description = post.metadata?.seoDescription || "Sin descripción disponible.";

// Metabolic Metrics
const impactLevel = post.metadata?.impact || "Análisis Pendiente";

let effortScore: string;
if (typeof post.metadata?.effort === 'number') {
    // Generate bars visual representation (e.g. "4/5")
    effortScore = `${post.metadata.effort}/5`;
} else {
    effortScore = post.metadata?.effort || "N/A";
}
---

<div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl border border-gray-100/50 overflow-hidden transition-all duration-300 hover:-translate-y-1 h-full flex flex-col relative w-full">
    {/* Generative Abstract Cover */}
    <a href={postUrl} class="block h-[180px] bg-gradient-to-br from-emerald-50 to-blue-50 flex items-center justify-center relative overflow-hidden focus:outline-none">
        <div class="text-[#007BFF]/40 transition-transform duration-500 group-hover:scale-110">
            <IconComponent class="w-16 h-16 stroke-[1.5]" />
        </div>
        
        {/* Top Badges Area */}
        <div class="absolute top-4 inset-x-4 flex justify-between items-start z-20">
            {post.metadata?.youtubeUrl ? (
                <a href={post.metadata.youtubeUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-2.5 py-1 text-[10px] font-bold text-white bg-red-600/90 hover:bg-red-500 backdrop-blur-md rounded-md shadow-sm transition-colors hover:scale-105" title="Ver Video en YouTube">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
                    ORIGINAL
                </a>
            ) : (
                <div></div>
            )}
            <span class="inline-flex items-center px-3 py-1 text-xs font-semibold text-gray-700 bg-white/80 backdrop-blur-sm rounded-full shadow-sm pointer-events-none">
                {postCategory}
            </span>
        </div>
    </a>

    <div class="p-8 flex-1 flex flex-col relative">
        {/* Metabolic Badges */}
        <div class="flex flex-wrap items-center gap-2 mb-3">
            <span class="inline-flex items-center gap-1 text-[10px] font-bold text-gray-500 uppercase tracking-widest border border-gray-200 rounded-sm px-1.5 py-0.5">
                <Flame class="w-3 h-3 text-orange-500" />
                Impacto: {impactLevel}
            </span>
            <span class="inline-flex items-center gap-1 text-[10px] font-bold text-gray-500 uppercase tracking-widest border border-gray-200 rounded-sm px-1.5 py-0.5">
                <Dumbbell class="w-3 h-3 text-gray-600" />
                Esfuerzo: {effortScore}
            </span>
            {post.metadata?.biomarker && (
                <span class="inline-flex items-center gap-1 text-[10px] font-bold text-[#007BFF] uppercase tracking-widest border border-[#007BFF]/20 bg-[#007BFF]/5 rounded-sm px-1.5 py-0.5">
                    <Activity class="w-3 h-3" />
                    {post.metadata.biomarker}
                </span>
            )}
        </div>

        <h3 class="text-xl font-bold mb-3 text-gray-900 group-hover:text-[#007BFF] transition-colors line-clamp-2 leading-tight">
            <a href={postUrl} class="focus:outline-none hover:underline decoration-2 underline-offset-4 decoration-[#007BFF]/40">
                {postTitle}
                <span class="absolute inset-0 z-10" aria-hidden="true"></span>
            </a>
        </h3>

        <div class="flex items-center gap-3 text-sm text-gray-400 mb-4 z-20 relative">
            <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                {publishedDate}
            </span>
            <span>·</span>
            <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {readingTime} min
            </span>
        </div>

        <p class="text-gray-600 mb-6 line-clamp-3 leading-relaxed flex-1 z-20 relative">
            {description}
        </p>

        {/* Footer Actions */}
        <div class="flex items-center justify-between pt-4 border-t border-gray-100 z-20 relative">
            <a href={postUrl} class="inline-flex items-center text-[#007BFF] font-bold group-hover:underline decoration-2 underline-offset-2 transition-all text-sm">
                Leer Artículo
                <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            
            {/* ElenaApp CTA (Fake Button to show ecosystem link) */}
            <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-[#00C49A]/10 text-[#00C49A] rounded-full text-xs font-bold transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                Activar Protocolo
            </div>
        </div>
    </div>
</div>
