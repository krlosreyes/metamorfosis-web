---
// Navbar with glassmorphism effect
---

<nav
    class="fixed top-0 left-0 right-0 z-50 backdrop-blur-lg bg-white/70 border-b border-gray-200/50"
>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-2">
                <img
                    src="/logoSite.png"
                    alt="Logo Metamorfosis Real"
                    class="h-10 w-auto"
                />
                <span class="font-bold text-xl hidden md:block"
                    >Metamorfosis Real</span
                >
            </a>

            <!-- Desktop Navigation Links Removed for Squeeze Page Phase 0 -->
            <div class="hidden md:flex items-center space-x-8"></div>

            <div class="flex items-center gap-4">
                <!-- CTA Button Removed for Squeeze Page Phase 0 -->
            </div>
        </div>
    </div>
</nav>
<!-- Spacer to prevent content from hiding under fixed navbar -->
<div class="h-16"></div>

