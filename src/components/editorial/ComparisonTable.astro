---
// src/components/editorial/ComparisonTable.astro
interface Comparison {
    concept: string;
    myth: string;
    reality: string;
}

interface Props {
    comparisons: Comparison[];
}

const { comparisons } = Astro.props;
---

<div class="my-12 overflow-hidden bg-white border border-gray-200 rounded-2xl shadow-sm">
    <div class="bg-gray-50 border-b border-gray-200 px-6 py-4">
        <h3 class="text-lg font-bold text-gray-900 m-0 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
            Análisis Desmitificador
        </h3>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-gray-200 bg-gray-50/50">
                    <th class="py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs whitespace-nowrap w-1/4">Concepto Core</th>
                    <th class="py-4 px-6 font-bold text-red-400 uppercase tracking-wider text-xs w-1/3">El Mito Popular</th>
                    <th class="py-4 px-6 font-bold text-emerald-600 uppercase tracking-wider text-xs w-5/12 border-l border-emerald-100 bg-emerald-50/30">Realidad Científica</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {comparisons.map((comp, index) => (
                    <tr class={`transition-colors hover:bg-gray-50 ${index % 2 === 0 ? 'bg-white' : 'bg-gray-50/30'}`}>
                        <td class="py-5 px-6 align-top">
                            <span class="inline-block px-2.5 py-1 bg-gray-100 text-gray-700 font-mono text-xs font-semibold rounded border border-gray-200">
                                {comp.concept}
                            </span>
                        </td>
                        <td class="py-5 px-6 text-gray-500 align-top text-sm leading-relaxed">
                            <div class="flex gap-2">
                                <svg class="w-4 h-4 text-red-300 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                <span>{comp.myth}</span>
                            </div>
                        </td>
                        <td class="py-5 px-6 text-gray-900 align-top text-sm leading-relaxed border-l border-emerald-50 bg-emerald-50/10 font-medium">
                            <div class="flex gap-2">
                                <svg class="w-4 h-4 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                <span>{comp.reality}</span>
                            </div>
                        </td>
                    </tr>
                ))}
            </tbody>
        </table>
    </div>
</div>
