---
// src/components/editorial/ProtocolStepper.astro
interface Step {
    title: string;
    description: string;
    time?: string;
}

interface Props {
    title?: string;
    steps: Step[];
}

const { title = "Cronograma Metabólico", steps } = Astro.props;
---

<div class="my-12 p-6 bg-white border border-gray-200 rounded-3xl shadow-sm">
    <div class="mb-8 flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 m-0">{title}</h3>
    </div>

    <div class="relative pl-4 sm:pl-6">
        {/* Línea Vertical Continua */}
        <div class="absolute left-[1.35rem] sm:left-[1.85rem] top-2 bottom-6 w-0.5 bg-gradient-to-b from-blue-200 via-emerald-200 to-gray-100 rounded-full"></div>

        <div class="space-y-8">
            {steps.map((step, index) => (
                <div class="relative group">
                    {/* Indicador Numérico / Icono */}
                    <div class="absolute -left-[1.85rem] sm:-left-[2.35rem] top-0 w-8 h-8 rounded-full bg-white border-2 border-blue-500 shadow-sm flex items-center justify-center z-10 transition-transform group-hover:scale-110 group-hover:border-emerald-500">
                        <span class="text-xs font-bold text-gray-700 bg-white w-full h-full rounded-full flex items-center justify-center">{index + 1}</span>
                    </div>

                    <div class="pl-6 pb-2 transition-all duration-300 group-hover:translate-x-1">
                        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3 mb-2">
                            <h4 class="text-lg font-bold text-gray-900 m-0 group-hover:text-blue-700 transition-colors">
                                {step.title}
                            </h4>
                            {step.time && (
                                <span class="inline-flex items-center text-xs font-mono font-bold tracking-widest uppercase text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded border border-emerald-100">
                                    <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    {step.time}
                                </span>
                            )}
                        </div>
                        <p class="text-gray-600 leading-relaxed text-sm bg-gray-50/50 rounded-lg p-4 border border-gray-100 m-0 group-hover:border-blue-100 transition-colors">
                            {step.description}
                        </p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</div>
